<div class="container mt-4">
    <div class="row">

        @foreach (var item in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card">

                    <div class="bg-image hover-overlay ripple">
                        <img src="https://via.placeholder.com/400x200" class="img-fluid" />
                    </div>

                    <div class="card-body">
                        <h5 class="card-title"></h5>
                        <p class="card-text">
                            
                        </p>

                        <a asp-action="Details" asp-route-id="" class="btn btn-primary">
                            Ver más
                        </a>

                        <a asp-action="Edit" asp-route-id="" class="btn btn-warning">
                            Editar
                        </a>

                        <a asp-action="Delete" asp-route-id="" class="btn btn-danger">
                            Eliminar
                        </a>
                    </div>

                </div>
            </div>
        }

    </div>
</div>